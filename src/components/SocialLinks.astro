---
// Inline SVG icons. Keeping them inline avoids extra HTTP requests and lets
// them inherit currentColor.
import { links } from '../data/cv';

interface Props {
  /** Tailwind class string applied to each <a>. */
  class?: string;
  /** Tailwind class string applied to the wrapper. */
  wrapClass?: string;
  /** When true, show the handle next to the icon. */
  showHandle?: boolean;
  /** Icon size in px. */
  size?: number;
}

const {
  class: linkClass = 'text-ink-700 hover:text-ink-900 transition-colors',
  wrapClass = 'flex items-center gap-4',
  showHandle = false,
  size = 20,
} = Astro.props;
---

<ul class={wrapClass}>
  {links.map((l) => (
    <li>
      <a
        href={l.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={l.label}
        class={`inline-flex items-center gap-2 ${linkClass}`}
      >
        {l.label === 'LinkedIn' && (
          <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
          </svg>
        )}
        {l.label === 'GitHub' && (
          <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1-.02-1.96-3.2.69-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18a10.95 10.95 0 0 1 5.76 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
          </svg>
        )}
        {l.label === 'Google Scholar' && (
          <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z" />
          </svg>
        )}
        {showHandle && <span class="font-sans text-sm">{l.handle}</span>}
      </a>
    </li>
  ))}
</ul>
