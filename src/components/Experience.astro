---
import { experience } from '../data/cv';
---

<section id="experience" class="border-b border-ink-200 bg-ink-50/40">
  <div class="container-readable py-20 md:py-24">
    <p class="label-eyebrow mb-4">Industry experience</p>
    <h2 class="text-3xl md:text-4xl font-semibold rule-heading mb-12">Selected roles</h2>

    <ol class="space-y-16">
      {experience.map((role) => (
        <li>
          <div class="grid md:grid-cols-12 gap-4 md:gap-8">
            <div class="md:col-span-4">
              <div class="mb-4 flex h-10 items-center" aria-hidden="true">
                <img
                  src={role.logo}
                  alt=""
                  class="max-h-10 w-auto max-w-[140px] object-contain opacity-80"
                  loading="lazy"
                />
              </div>
              <p class="text-xl font-semibold text-ink-900">{role.org}</p>
              <p class="mt-1 font-serif italic text-ink-700">{role.role}</p>
              <p class="mt-3 font-sans text-sm uppercase tracking-wider text-ink-700">
                {role.period}
              </p>
              <p class="font-sans text-sm text-ink-500">{role.location}</p>
            </div>
            <ul class="md:col-span-8 space-y-3 text-ink-900 leading-relaxed">
              {role.bullets.map((b) => (
                <li class="relative pl-5">
                  <span
                    class="absolute left-0 top-[0.7em] block h-1.5 w-1.5 rounded-full bg-ink-800"
                    aria-hidden="true"
                  ></span>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
