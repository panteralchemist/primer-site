---
import { about, stats, education } from '../data/cv';
---

<section id="about" class="border-b border-ink-200">
  <div class="container-readable py-20 md:py-24">
    <div class="grid md:grid-cols-12 gap-12">
      <div class="md:col-span-4">
        <p class="label-eyebrow mb-4">About</p>
        <h2 class="text-3xl md:text-4xl font-semibold rule-heading">Process chemistry, end&nbsp;to&nbsp;end.</h2>
      </div>
      <div class="md:col-span-8 space-y-5 text-lg leading-relaxed">
        {about.map((p) => <p set:html={p} />)}
      </div>
    </div>

    <!-- Stat strip -->
    <dl class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-px bg-ink-200 border border-ink-200">
      {stats.map((s) => (
        <div class="bg-paper p-6">
          <dt class="label-eyebrow">{s.label}</dt>
          <dd class="mt-2 text-3xl md:text-4xl font-semibold tracking-tight text-ink-800">
            {s.value}
          </dd>
        </div>
      ))}
    </dl>

    <!-- Education -->
    <div class="mt-16">
      <h3 class="text-xl font-semibold rule-heading mb-8">Education</h3>
      <ul class="space-y-6">
        {education.map((e) => (
          <li class="grid md:grid-cols-12 gap-4">
            <div class="md:col-span-4">
              <p class="font-semibold text-ink-900">{e.school}</p>
              <p class="font-sans text-sm text-ink-700">{e.period}</p>
            </div>
            <div class="md:col-span-8">
              <p class="text-ink-900">{e.degree}</p>
              <p class="mt-1 text-ink-700 leading-relaxed">{e.detail}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
