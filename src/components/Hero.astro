---
import { Image } from 'astro:assets';
import { profile } from '../data/cv';
import headshot from '../assets/headshot.jpg';
---

<section id="top" class="border-b border-ink-200 bg-paper">
  <div class="container-readable py-20 md:py-28">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7 order-2 lg:order-1">
        <p class="label-eyebrow mb-6">{profile.org} · {profile.location}</p>
        <h1 class="text-4xl md:text-6xl font-semibold leading-[1.05] tracking-tight">
          {profile.name}
        </h1>
        <p class="mt-3 text-xl md:text-2xl font-serif italic text-ink-700">
          {profile.title}
        </p>

        <p class="mt-10 max-w-prose text-lg md:text-xl leading-relaxed text-ink-900/90">
          {profile.tagline}
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="#experience" class="btn-primary">
            See work
            <span aria-hidden="true">→</span>
          </a>
          <a href="#contact" class="btn-secondary">Get in touch</a>
        </div>
      </div>

      <div class="lg:col-span-5 order-1 lg:order-2">
        <figure class="mx-auto max-w-sm lg:max-w-none">
          <Image
            src={headshot}
            alt={`Portrait of ${profile.name}`}
            widths={[480, 720, 960]}
            sizes="(min-width: 1024px) 360px, (min-width: 640px) 320px, 75vw"
            format="webp"
            quality={82}
            class="aspect-[4/5] w-full object-cover object-center shadow-xl shadow-ink-900/15"
          />
        </figure>
      </div>
    </div>
  </div>
</section>
