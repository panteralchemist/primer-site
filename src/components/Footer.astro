---
import { profile } from '../data/cv';
import SocialLinks from './SocialLinks.astro';
const year = new Date().getFullYear();
---

<footer class="bg-ink-900 text-ink-100">
  <div class="container-readable py-12 grid md:grid-cols-12 gap-8 items-end">
    <div class="md:col-span-7">
      <p class="font-serif text-2xl font-semibold tracking-tight">{profile.shortName}</p>
      <p class="mt-2 font-sans text-sm text-ink-300">
        {profile.title} · {profile.location}
      </p>
      <SocialLinks
        wrapClass="mt-6 flex items-center gap-6"
        class="text-ink-300 hover:text-paper transition-colors"
        size={20}
        showHandle={true}
      />
    </div>
    <div class="md:col-span-5 md:text-right">
      <p class="font-sans text-xs uppercase tracking-[0.18em] text-ink-300">
        © {year} {profile.shortName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
